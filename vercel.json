{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/auto-scan", "schedule": "15 14 * * 1-5" },
    { "path": "/api/monitor", "schedule": "0 18 * * 1-5" },
    { "path": "/api/monitor", "schedule": "25 20 * * 1-5" }
  ]
}
